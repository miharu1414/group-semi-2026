# ============================================================
# 班ゼミカレンダー 2026 — 環境変数テンプレート
# ============================================================
# このファイルをコピーして .env.local を作成し、値を入力してください。
#   cp .env.example .env.local
#
# .env.local は .gitignore に含まれており、コミットされません。
# ============================================================

# ----------------------------------------------------------
# Cloudflare 認証
# ----------------------------------------------------------
# `wrangler login` でブラウザ認証する場合は不要。
# CI/CD（GitHub Actions等）やスクリプトでデプロイする場合に設定してください。
#
# 取得方法: Cloudflare Dashboard → My Profile → API Tokens
# 必要な権限: Cloudflare Pages:Edit, D1:Edit
CLOUDFLARE_API_TOKEN=

# 取得方法: Cloudflare Dashboard 右上のアカウントID（または `wrangler whoami`）
CLOUDFLARE_ACCOUNT_ID=

# ----------------------------------------------------------
# Node.js バージョン（Cloudflare Pages ビルド設定用）
# ----------------------------------------------------------
NODE_VERSION=18

# ----------------------------------------------------------
# Cloudflare D1 データベースID
# ----------------------------------------------------------
# wrangler.toml の database_id に直接記入するため、通常ここには不要。
# `npm run db:create` 実行後に表示される値を wrangler.toml に貼り付けてください。
# D1_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
