# ============================================================
# .env.local — ローカル開発専用（コミット禁止）
# ============================================================
# cp .env.local.example .env.local
# .gitignore に .env.local が含まれていることを確認してください。
# ============================================================

# ----------------------------------------------------------
# Cloudflare 認証（どちらかを選択）
# ----------------------------------------------------------

# 【方法A】wrangler login でブラウザ認証する場合 → 以下は不要
# 【方法B】CI/CD や複数人開発でAPIトークンを使う場合 → 以下を入力

# 取得: Cloudflare Dashboard → My Profile → API Tokens → Create Token
# テンプレート「Edit Cloudflare Workers」を選択し、D1権限を追加
CLOUDFLARE_API_TOKEN=

# 取得: Cloudflare Dashboard の右サイドバー "Account ID"
#      または `npx wrangler whoami` コマンド
CLOUDFLARE_ACCOUNT_ID=

# ----------------------------------------------------------
# ビルド設定
# ----------------------------------------------------------
NODE_VERSION=20
